generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_OWNER
  BRANCH_MANAGER
  ACCOUNTANT
  SALES_EXECUTIVE
  INVENTORY_MANAGER
  SUPPORT
  AUDITOR
  READ_ONLY
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  phone            String?         @unique
  password         String?         // Optional for Google Login
  name             String?
  isEmailVerified  Boolean         @default(false)
  isPhoneVerified  Boolean         @default(false)
  googleId         String?         @unique
  twoFactorEnabled Boolean         @default(false)
  twoFactorSecret  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  companies        CompanyUser[]
  deviceSessions   DeviceSession[]
}

model DeviceSession {
  id           String   @id @default(uuid())
  userId       String
  deviceOs     String?
  ipAddress    String?
  refreshToken String?  @unique
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id           String        @id @default(uuid())
  name         String
  panNumber    String?
  website      String?
  contactEmail String?
  logoUrl      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  users        CompanyUser[]
  branches     Branch[]
  customers    Customer[]
  items        Item[]
  invoices     Invoice[]
}

model Branch {
  id         String   @id @default(uuid())
  companyId  String
  name       String
  address    String?
  gstin      String?
  stateCode  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users      CompanyUser[]
}

model CompanyUser {
  id         String   @id @default(uuid())
  userId     String
  companyId  String
  branchId   String?  // If null, they have company-wide access
  role       Role     @default(READ_ONLY)
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, branchId])
}

// -----------------------------------------------------------------------------
// Legacy Phase models (To be expanded in later phases)
// -----------------------------------------------------------------------------

model Customer {
  id         String   @id @default(uuid())
  companyId  String
  name       String
  email      String?
  phone      String?
  gstin      String?
  address    String?
  stateCode  String?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices   Invoice[]
}

model Item {
  id           String        @id @default(uuid())
  companyId    String
  name         String
  hsnSac       String?
  price        Decimal
  taxRate      Decimal
  stock        Int           @default(0)
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
}

enum InvoiceType {
  SALES
  PURCHASE
  PROFORMA
  DELIVERY_CHALLAN
}

model Invoice {
  id            String        @id @default(uuid())
  companyId     String
  customerId    String
  type          InvoiceType   @default(SALES)
  invoiceNumber String
  date          DateTime
  totalAmount   Decimal
  cgst          Decimal
  sgst          Decimal
  igst          Decimal
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]
}

model InvoiceItem {
  id         String   @id @default(uuid())
  invoiceId  String
  itemId     String
  quantity   Int
  rate       Decimal
  amount     Decimal
  cgst       Decimal
  sgst       Decimal
  igst       Decimal
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}
